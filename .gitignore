# Root-level ignores. backend/ and mobile/ have their own; this file covers the
# repo root, which had none — meaning a stray root .env was one `git add .` away
# from being committed.

# Secrets — never commit, in any form.
.env
.env.*
!.env.example
# publishable anon key only — founder decision 1 (REBUILD_STATE.md)
!.env.development

# Dependencies
node_modules/

# Native projects — CNG (Continuous Native Generation). Regenerated by
# `expo prebuild` / `expo run:ios`; never committed, so app.json stays the
# single source of native config. Local-only native tweaks are lost on prebuild.
/ios/
/android/

# Expo build cache + generated types
.expo/

# macOS
.DS_Store

# resumable scratch cache for scripts/audit-table-provenance.mjs
backend/scripts/provenance-cache-*.json

# @generated expo-cli sync-2b81b286409207a5da26e14c78851eb30d8ccbdb
# The following patterns were generated by expo-cli

expo-env.d.ts
# @end expo-cli
# Signing secrets — never track (untracked 2026-07-22; rotate the dist cert in Apple Developer)
mobile/credentials.json
mobile/credentials/ios/*.p12
mobile/credentials/ios/*.mobileprovision
