# Otto backend — environment variables.
# Copy to `.env` and fill in real values. `.env` is gitignored; never commit secrets.
# Mirror these in the Railway service (Variables tab) — that's what production reads.

# --- Core (required) ---
PORT=5001
NODE_ENV=development
DATABASE_URL=postgres://...            # Neon/Supabase Postgres connection string

# --- Supabase (required) ---
SUPABASE_URL=https://mepzfdefanfpnrvydyty.supabase.co
SUPABASE_ANON_KEY=                     # public anon key
SUPABASE_SERVICE_ROLE_KEY=             # sb_secret_... — admin (account deletion). SERVER-ONLY.

# --- AI features (optional; recipe create + photo/URL import stay dormant without it) ---
ANTHROPIC_API_KEY=                     # sk-ant-... — models: claude-opus-4-8, claude-haiku-4-5

# --- Optional ---
SENTRY_DSN=                            # error tracking; dormant when empty
SPOONACULAR_KEY=                       # nutrition test-batch ingest only
META_OEMBED_TOKEN=                     # "appid|appsecret" — raises IG oEmbed limits
SHARE_BASE_URL=https://ottosapp.com    # public origin for share links (falls back to request host)
WEB_ORIGINS=                           # extra CORS origins, comma-separated
THEMEALDB_KEY=                         # supporter key; falls back to dev key "1". SERVER-ONLY.
